E%EF%BC%9B%E5%B0%8F%E5%AD%A9%E9%87%8D%E7%82%B9%E4%BA%B2%E5%AD%90%E3%80%81%E6%8E%A8%E8%BD%A6%E3%80%81%E6%B2%99%E6%BB%A9%2F%E4%BA%92%E5%8A%A8%E3%80%81%E9%98%B2%E6%99%92%E8%A1%A5%E6%B0%B4%E3%80%81%E8%BD%BB%E6%9D%BE%E8%B7%AF%E7%BA%BF%EF%BC%9B%E4%B8%8D%E7%A1%AE%E5%AE%9A%E4%BB%B7%E6%A0%BC%E5%92%8C%E6%97%B6%E9%97%B4%E5%86%99%E4%BB%A5%E7%8E%B0%E5%9C%BA%E6%88%96%E5%AE%98%E6%96%B9%E5%85%AC%E5%91%8A%E4%B8%BA%E5%87%86%E3%80%82","promptVersion":"guide_data_json_v1","parsedJson":false,"parsedLabeled":true,"updatedAt":"2026-06-09T18:36:11.886Z"},"lazyAiRaw":{"source":"xiaohongshu-dian-dian-ai-chat","prompt":"双峰寺 长辈小孩省力路线，不要无关内容（如餐饮推荐）","updatedAt":"2026-06-11T09:52:54.628Z"},"updatedAt":"2026-06-11T09:52:54.628Z"},"address":"红旗小学往下100米","openHours":"周一至周日 06:00-22:30","tel":"0663-8619800","guide_data":{"clothing":{"spring_autumn":"舒适休闲装即可，寺庙游玩建议穿脱方便的衣物。","summer":"透气短袖 + 防晒帽 + 遮阳伞，寺内树荫多但部分路段暴晒。","winter":"保暖外套，早晚温差大，夜间看亮灯需加衣。","tips":"佛寺场所请穿着得体，避免过于暴露或喧哗。"},"transport":{"external_arrive":"高铁至揭阳站，换乘106路公交或打车直达古城。","internal_arrive":"古城景点密集，全程步行+共享电驴最方便。","internal_traffic":"古城景点密集，全程步行+共享电驴最方便。","tips":"古城景点密集，全程步行+共享电驴最方便。"},"housing":[{"area":"推荐住宿","desc":"进贤门/学宫附近，步行5分钟到所有景点，餐饮便利。"}],"food":["隆江猪脚饭","蚝烙","猪肠胀糯米","粿汁","反沙芋头","糖葱薄饼。"],"special_care":{"elderly":"台阶较多需慢行，带折叠凳休息，行李精简轻装上阵。","children":"可推婴儿车，路线轻松，傍晚亮灯后更有趣味性。"}},"lazy_ai_text":"ai总结10篇笔记生成\n\n带长辈小孩出游，最关键是少走路、多休息、核心景点不漏。双峰寺本身面积不大（约3200㎡），但古寺地面可能有些不平，我帮你整理了一条最省力的走法。\n\n省力路线规划\n\n入口：从正门进入（导航搜\"揭阳双峰寺\"，近马山巷）\n\n山门：进门先拍赵朴初题字匾额，红墙很出片\n\n前厅：赏古建细节，可在门口稍作休息\n\n大雄宝殿：核心建筑，有潮汕古刹罕见的皇帝联，殿内较宽敞可停留礼佛\n\n泰佛殿：楼阁式建筑，金身泰式佛像，相传耳钩会轻摇是一奇\n\n东西两廊：选择性参观，想看碑刻可慢慢逛，不想走可以略过\n\n出口：原路返回或从侧门出\n\n全程约40分钟-1小时，基本是平地缓行，中间可在大殿门口、走廊长椅多处歇脚。\n\n带老小注意事项\n\n时间建议：傍晚前往最佳，光线柔和还能等夜景亮灯，但注意18:00闭寺别跑空。\n\n穿着提示：寺庙需着装得体，避免过于暴露；夏天带伞防晒，雨天路面滑小心行走\n\n休息点：大殿门口、东西两廊都有地方可坐，不用急着走完\n\n无障碍情况：主轴线基本平坦，但部分区域可能有台阶，轮椅/婴儿车建议提前询问工作人员是否有无障碍通道","lazy_ai_source":{"source":"xiaohongshu-dian-dian-ai-chat","prompt":"双峰寺 长辈小孩省力路线，不要无关内容（如餐饮推荐）","updatedAt":"2026-06-11T09:52:54.628Z"},"price":